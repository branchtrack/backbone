  "url": "http://backbonejs.org",
  "keywords": [
    "model",
    "view",
    "controller",
    "router",
    "server",
    "client",
    "browser"
  ],
  "author": "Jeremy Ashkenas",
  "dependencies": {
    "lodash-es": "^4.17.21"
  },
  "devDependencies": {
    "@vitest/ui": "^1.3.1",
    "eslint": "^8.7.0",
    "eslint-plugin-import": "^2.28.1",
    "jsdom": "^24.0.0",
    "vite": "^5.1.4",
    "vitest": "^1.3.1"
  },
  "scripts": {
    "test": "vitest run",
